APP_NAME=face-compare-service

FACE_DETECT_MODEL=/app/models/face_detection_yunet_2023mar.onnx
FACE_RECOGNITION_MODEL=/app/models/face_recognition_sface_2021dec.onnx

# Default awal SFace cosine threshold.
# OpenCV mencantumkan threshold cosine LFW sekitar 0.363.
# Nanti kalibrasi dengan data absensi real.
FACE_THRESHOLD=0.363

DETECT_SCORE_THRESHOLD=0.90
DETECT_NMS_THRESHOLD=0.30
DETECT_TOP_K=5000

MAX_UPLOAD_MB=8

# Untuk absensi sebaiknya false.
ALLOW_MULTIPLE_FACES=false

# Irit resource CPU.
OPENCV_THREADS=1

# Auth code untuk akses endpoint /verify
# Ganti dengan string panjang/random.
FACE_API_AUTH_CODE=
